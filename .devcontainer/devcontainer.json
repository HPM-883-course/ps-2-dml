{
  "name": "HPM 883 PS-2 Environment",
  "image": "ghcr.io/dheplab/docker-debian-r-studio:v0.0.5",
  "containerEnv": {
    "RENV_PATHS_CACHE": "/home/rstudio/.cache/R/renv"
  },
  "postCreateCommand": "R -e 'renv::restore(prompt = FALSE)'",
  "customizations": {
    "codespaces": {
      "openFiles": ["ps-2-dml.qmd"]
    },
    "vscode": {
      "extensions": ["quarto.quarto", "reditorsupport.r"]
    }
  },
  "forwardPorts": [8787],
  "portsAttributes": {
    "8787": {
      "label": "RStudio Server",
      "onAutoForward": "notify"
    }
  }
}
